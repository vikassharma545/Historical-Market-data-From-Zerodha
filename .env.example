# PyZData environment variable configuration
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit your .env file to source control.

# ---- Zerodha credentials (use ONE of the two auth methods) ----

# Option A: pre-obtained enctoken (preferred — no login round-trip)
# PYZDATA_ENCTOKEN=your_enctoken_here

# Option B: full credential login
# PYZDATA_USER_ID=AB1234
# PYZDATA_PASSWORD=your_password
# PYZDATA_TOTP=your_totp_secret   # static TOTP secret for automation

# ---- Performance tuning ----

# Number of parallel threads for monthly data fetches (default: 4)
# PYZDATA_MAX_WORKERS=4

# HTTP request timeout in seconds (default: 30)
# PYZDATA_TIMEOUT=30

# ---- Retry behaviour ----

# Total retry attempts on transient failures (default: 5)
# PYZDATA_MAX_RETRIES=5

# Exponential backoff factor in seconds (default: 1.0)
# Delays: 0s, 2s, 4s, 8s, 16s
# PYZDATA_BACKOFF_FACTOR=1.0

# ---- Rate limiting ----

# Maximum API requests per second (default: 3.0)
# Zerodha allows ~3 req/s for historical data.  Set to 0 to disable.
# PYZDATA_RATE_LIMIT=3.0

# ---- Instruments cache ----

# Hours before the instruments CSV is re-downloaded (default: 24)
# PYZDATA_CACHE_TTL_HOURS=24

# Override the default cache location (~/.pyzdata/instruments.csv)
# PYZDATA_CACHE_PATH=/path/to/custom/instruments.csv

# ---- Logging ----

# Log level for pyzdata internals: DEBUG, INFO, WARNING, ERROR (default: WARNING)
# PYZDATA_LOG_LEVEL=INFO
